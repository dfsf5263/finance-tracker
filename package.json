{
  "name": "finance-tracker",
  "version": "1.5.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm run generate:openapi && next build",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "start": "next start",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "lint": "eslint src/",
    "format": "biome format --write ./src ./prisma",
    "format:check": "biome format ./src ./prisma",
    "check": "npm run lint && npm run format:check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e": "npm run test:e2e:with-email && npm run test:e2e:no-email",
    "test:e2e:with-email": "playwright test",
    "test:e2e:no-email": "playwright test --config playwright.no-email.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "db:e2e:up": "docker compose -f docker-compose.e2e.yml up -d postgres-e2e",
    "db:e2e:down": "docker compose -f docker-compose.e2e.yml down postgres-e2e",
    "db:e2e:reset": "bash scripts/db-e2e-reset.sh",
    "lockfile-check": "npm install --package-lock-only --ignore-scripts 2>/dev/null && git diff --exit-code package-lock.json || (echo '\\n✗ package-lock.json is out of sync. Run: npm install' && exit 1)",
    "postinstall": "test -d .git && simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lockfile-check"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.5.6",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@scalar/nextjs-api-reference": "^0.10.4",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.18.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-sankey": "^0.12.3",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "exceljs": "^4.4.0",
    "fast-levenshtein": "^3.0.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "postcss": "^8.5.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-qr-code": "^2.0.18",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^29.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.5.0",
    "simple-git-hooks": "^2.13.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^3.1.0"
  }
}
